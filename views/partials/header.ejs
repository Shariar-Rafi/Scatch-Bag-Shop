<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scatch</title>
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>

  <body class="font-['helvetica_now_display']">
    <nav class="w-full px-5 py-3 flex items-center justify-between">
      <a href="/"><h3 class="text-xl">Scatch</h3></a>
      <div class="flex gap-5">
        <% var loggedIn = typeof loggedIn !== "undefined" ? loggedIn : true  %>

        <% if(loggedIn){ %>
          <a href="/">Home</a>
          <a href="/shop">Shop</a>
          <a href="/owners/admin">Admin</a>
          <a href="/users/profile">My Account</a>
          <a href="/cart">Cart</a>
        </div>
        <a class="text-red-600" href="/users/logout">Logout</a>
        <% } %>
    </nav>
  </body>
</html>
