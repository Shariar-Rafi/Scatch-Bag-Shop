<%- include('./partials/header') %>
<div class="w-full h-screen flex items-start px-20 py-20 gap-10">
  <div class="w-[25%] rounded-md overflow-hidden">
    <div
      class="w-full h-80 bg-[<%= user.cart[0].bgColor %>] flex items-center justify-center"
    >
      <img
        class="h-[18rem]"
        src="data:image/jpeg;base64,<%= user.cart[0].image.toString('base64') %>"
        alt="image"
      />
    </div>
    <div
      class="w-full flex justify-between px-5 py-4 bg-[<%= user.cart[0].panelColor %>]"
    >
      <h3 class="text-xl">Product:</h3>
      <h3 class="text-xl"><%= user.cart[0].name %></h3>
    </div>
    <div
      class="flex items-center justify-between px-5 py-3 bg-[<%= user.cart[0].textColor %>] text-white"
    >
      <h4 class="text-lg">Net Total:</h4>
      <h2 class="text-lg">৳ <%= bill %></h2>
    </div>
  </div>
  <div class="w-[75%]">
    <h3 class="text-xl">Price Breakdown</h3>
    <div class="px-10 mt-5">
      <div class="flex mt-2">
        <h4 class="w-1/3">Total MRP</h4>
        <h4>৳ <%= user.cart[0].price %></h4>
      </div>
      <div class="flex mt-2">
        <h4 class="w-1/3">Discount on MRP</h4>
        <h4>৳ <%= user.cart[0].discount %></h4>
      </div>
      <div class="flex mt-2">
        <h4 class="w-1/3">Platform Fee</h4>
        <h4>৳ 20</h4>
      </div>
      <div class="flex mt-2">
        <h4 class="w-1/3">Shipping Fee</h4>
        <h4>FREE</h4>
      </div>
    </div>
    <div class="w-full h-[1px] bg-black mt-10"></div>
    <div class="flex mt-5">
      <h3 class="w-1/3 text-xl">Total Amount</h3>
      <h3 class="font-semibold text-xl text-green-600">৳ <%= bill %></h3>
    </div>
    <form action=""></form>
  </div>
</div>
<%- include('./partials/footer') %>
